# Copie para .env e preencha. O .env não vai pro git (ver .gitignore).

# --- MinIO / bucket (obrigatório) ---
MINIO_ENDPOINT=
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=flor-de-aco-foundation

# --- Overrides de disco (opcional) ---
# Use quando o disco do projeto for pequeno: o SIM acumula vários GB de
# .dbc em LANDING_DIR durante uma execução, e PUBLISH_CACHE_DIR guarda uma
# cópia do dataset publicado. Sem override, tudo fica em data/ do projeto.
#
# FLOR_DE_ACO_LANDING_DIR=
# FLOR_DE_ACO_PROCESSED_DIR=
FLOR_DE_ACO_MANUAL_DIR=
# FLOR_DE_ACO_PUBLISH_CACHE_DIR=
# DUCKDB_TEMP_DIR=
